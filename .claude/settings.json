{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(python *)",
            "command": ".venv/Scripts/python.exe .claude/hooks/python_command_guard.py",
            "timeout": 5,
            "statusMessage": "Checking project Python command"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".venv/Scripts/python.exe .claude/hooks/py_compile_check.py",
            "timeout": 15,
            "statusMessage": "Syntax-checking edited Python"
          }
        ]
      }
    ]
  }
}
